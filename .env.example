# ──────────────────────────────────────────────────────────────────────────────
# GammIA – Variables de entorno
# Copia este archivo como .env y rellena los valores antes de levantar Docker.
# NUNCA subas .env al repositorio (está en .gitignore).
# ──────────────────────────────────────────────────────────────────────────────

# ── Base de datos PostgreSQL ──────────────────────────────────────────────────
POSTGRES_USER=gammia
POSTGRES_PASSWORD=CAMBIA_ESTA_CONTRASENA
POSTGRES_DB=gammiadb

# URL completa (generada automáticamente por docker-compose, no cambiar aquí)
# DATABASE_URL=postgresql+asyncpg://gammia:password@db:5432/gammiadb

# ── Google Gemini API ─────────────────────────────────────────────────────────
GOOGLE_API_KEY=AIzaSy...tu_clave_aqui
MODEL_ID=gemini-2.5-flash

# ── Google Service Account (Drive Sync) ──────────────────────────────────────
# Ruta dentro del contenedor al archivo JSON de la cuenta de servicio
GOOGLE_SERVICE_ACCOUNT_FILE=/app/service_account.json

# ── Widget Interno ────────────────────────────────────────────────────────────
# Secreto compartido para el widget embebido en Google Sites (intranet)
WIDGET_INTERNAL_SECRET=secreto_intranet_gamma

# ── JWT Admin Auth ────────────────────────────────────────────────────────────
# CRÍTICO: Genera con: python -c "import secrets; print(secrets.token_hex(32))"
# En GCP: almacenar en Secret Manager (gammia-jwt-secret) — NO poner aquí en prod
JWT_SECRET_KEY=cambia-esto-por-una-clave-muy-larga-y-aleatoria-produccion
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Admin por defecto (se crea al primer arranque si no existe ningún admin) ──
# IMPORTANTE: Cambiar contraseña inmediatamente tras el primer despliegue
ADMIN_DEFAULT_EMAIL=admin@gammaingenieros.com
ADMIN_DEFAULT_PASSWORD=Gamma2024!

# ── CORS — Orígenes permitidos ────────────────────────────────────────────────
# Lista de orígenes separados por coma. NUNCA usar * en producción.
# Local:      http://localhost:5173,http://localhost:3000
# Producción: https://admin.gammaingenieros.com,https://gammaingenieros.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── MCP — Servidor de Certificaciones (red local Gamma) ──────────────────────
# Vacío → desarrollo local (subprocess stdio, requiere VPN activa)
# URL   → producción GCP (servidor SSE corriendo en la red de Gamma)
# Ejemplo producción: MCP_CERTIFICATIONS_URL=http://10.128.0.5:8001/sse
MCP_CERTIFICATIONS_URL=

# Puerto y host del servidor MCP SSE (se usa al correr certifications_mcp.py sse)
MCP_HOST=0.0.0.0
MCP_PORT=8001

# ── Configuración FastAPI ─────────────────────────────────────────────────────
PROJECT_NAME=GammIA API
VERSION=1.0.0
